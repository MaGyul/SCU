[
  {
    "text": "scu",
    "description": "Shadow Corridor Utility Commands",
    "children": [
      {
        "text": "audio",
        "description": "Audio related commands",
        "children": [
          {
            "text": "controlEnding",
            "description": "Enable or disable control of ending music.",
            "args": [
              { "text": "enable", "type": "boolean", "description": "" }
            ]
          },
          {
            "text": "controlMode",
            "description": "Set control mode to either mute or change ending music.",
            "args": [
              {
                "text": "mode",
                "type": "auto",
                "auto": ["mute", "change"],
                "description": ""
              }
            ]
          },
          {
            "text": "muteEnding",
            "description": "Manually mute ending music components currently playing."
          },
          {
            "text": "changeEnding",
            "description": "Manually change ending music to specified BGM (without package path, e.g. '09-dawn')",
            "args": [
              { "text": "bgm", "type": "string", "description": "" }
            ]
          }
        ]
      },
      {
        "text": "enemysc",
        "description": "Enemy Speed Controller commands",
        "children": [
          {
            "text": "setSpeed",
            "description": "Set enemy speed multiplier",
            "args": [
              { "text": "multiplier", "type": "number", "description": "" }
            ]
          },
          {
            "text": "setNotApply",
            "description": "Set enemies that should not be affected (comma separated)",
            "args": [
              { "text": "list", "type": "string", "description": "" }
            ]
          },
          { "text": "enable", "description": "Enable enemy speed control" },
          { "text": "disable", "description": "Disable enemy speed control" },
          { "text": "status", "description": "Show current status" }
        ]
      },
      {
        "text": "advanced",
        "description": "Advanced features commands",
        "children": [
          {
            "text": "mutekiMode",
            "description": "Enable or disable mutaki mode",
            "args": [
              { "text": "enable", "type": "boolean", "description": "" }
            ]
          },
          {
            "text": "stageStartSkip",
            "description": "Enable or disable stage start skip",
            "args": [
              { "text": "enable", "type": "boolean", "description": "" }
            ]
          },
          {
            "text": "cameraCooldown",
            "description": "Set camera cooldown time",
            "args": [
              { "text": "seconds", "type": "number", "description": "" }
            ]
          },
          { "text": "setQItem", "description": "Set Q item" },
          { "text": "useQItem", "description": "Use Q item" },
          {
            "text": "enemyHere",
            "description": "Move specified enemies near the player",
            "args": [
              { "text": "forward_distance", "type": "number", "description": "" }
            ]
          },
          {
            "text": "enemySpawn",
            "description": "Spawn specified number of enemies",
            "args": [
              { "text": "count", "type": "number", "description": "" }
            ]
          },
          {
            "text": "playMagatamaCharengeBGM",
            "description": "Play magatama charge BGM at specified volume",
            "args": [
              { "text": "volume", "type": "number", "description": "" }
            ]
          },
          { "text": "endMagatamaCharenge", "description": "End magatama charge" }
        ]
      },
      {
        "text": "custom",
        "description": "Custom features commands",
        "children": [
          {
            "text": "apply",
            "description": "Apply custom settings from JSON string",
            "args": [
              { "text": "json", "type": "string", "description": "" }
